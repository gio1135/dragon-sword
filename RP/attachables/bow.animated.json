{
  "format_version": "1.10.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "minecraft:bow.animated",
      "item": { "minecraft:bow": "!query.has_any_family('inanimate') && query.owner_identifier != 'minecraft:player'" },
      "materials": {
        "default": "entity_alphatest",
        "enchanted": "entity_alphatest_glint"
      },
      "textures": {
        "default": "textures/items/bow_standby",
        "bow_pulling_0": "textures/items/bow_pulling_0",
        "bow_pulling_1": "textures/items/bow_pulling_1",
        "bow_pulling_2": "textures/items/bow_pulling_2",
        "enchanted": "textures/misc/enchanted_item_glint"
      },
      "geometry": {
        "default": "geometry.bow_standby",
        "bow_pulling_0": "geometry.bow_pulling_0",
        "bow_pulling_1": "geometry.bow_pulling_1",
        "bow_pulling_2": "geometry.bow_pulling_2"
      },
      "scripts": {
        "initialize": [
          "variable.anim_frame = 0;"
        ],
        "pre_animation": [
          "variable.anim_frame = query.has_target * query.facing_target_to_range_attack * !query.is_sneaking * (variable.anim_frame + query.delta_time * 20);"
        ],
        "animate": [
          "rotate"
        ]
      },
      "animations": {
        "rotate": "animation.bow.rotate"
      },
      "render_controllers": [ "controller.render.bow_hostile" ]
    }
  }
}
