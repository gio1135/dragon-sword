{
  "namespace": "hud",
  "not_centered_gui_elements": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "regen_panel_non_centered": {
              "type": "panel",
              "offset": [2, 6.5],
              "size": ["0%c", "0%c"],
              "anchor_from": "top_left",
              "anchor_to": "top_left",
              "controls": [{ "regen_factory_non_centered@java_regen.regen_factory_non_centered": {} }],
              "bindings": [
                {
                  "binding_name": "#show_survival_ui",
                  "binding_name_override": "#visible"
                }
              ]
            }
          }
        ]
      }
    ]
  },
  "centered_gui_elements_at_bottom_middle": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "regen_panel": {
              "type": "panel",
              "size": ["100%c", 9],
              "controls": [{ "regen_factory@java_regen.regen_factory": {} }]
            }
          }
        ]
      }
    ]
  },
  "centered_gui_elements_at_bottom_middle_touch": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "regen_panel_clasic": {
              "type": "panel",
              "size": ["100%c", 9],
              "controls": [{ "regen_factory_clasic@java_regen.regen_factory_clasic": {} }]
            }
          }
        ]
      }
    ]
  },
  "anim_actionbar_text_alpha_out": {
    "anim_type": "alpha",
    "easing": "in_expo",
    "duration": 3,
    "from": 0,
    "to": 0,
    "destroy_at_end": "hud_actionbar_text",
    "end_event": "hud_actionbar_text_complete"
  },
  "anim_title_background_alpha_in": {
    "anim_type": "alpha",
    "easing": "linear",
    "duration": "$title_fade_in_time",
    "from": 0,
    "to": 0,
    "next": "@hud.anim_title_background_alpha_stay"
  },
  "anim_actionbar_text_background_alpha_out": {
    "anim_type": "alpha",
    "easing": "in_expo",
    "duration": 3,
    "from": 0,
    "to": 0,
    "destroy_at_end": "hud_actionbar_text",
    "end_event": "hud_actionbar_text_complete"
  }
}