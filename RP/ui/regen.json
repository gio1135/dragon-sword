  "regen_factory": {
    "type": "panel",
    "factory": {
      "name": "hud_actionbar_text_factory",
      "control_ids": { "hud_actionbar_text": "regen_panel@java_regen.regen_panel" }
    }
  },

  "render_heart": {
    "type": "image",
    "size": [9, 9],
    "anchor_from": "left_middle",
    "anchor_to": "left_middle",
    "texture": "textures/ui/heart_flash"
  }
